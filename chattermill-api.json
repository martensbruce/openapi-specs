{
  "openapi": "3.0.3",
  "info": {
    "title": "Chattermill API",
    "description": "The Chattermill API is a REST API that allows you to programmatically add, update, query, and delete customer feedback responses. It provides access to projects, data sources, data types, themes, categories, metrics, custom segments, and AI-powered insights.\n\nKey capabilities include:\n- Fetching and filtering feedback responses by date range, data source, and data type\n- Adding new feedback responses from external sources\n- Searching responses by attributes (e.g. email, customer ID) for GDPR data erasure\n- Querying AI-generated themes and sentiment analysis\n- Accessing project metrics such as NPS, CSAT, and custom formulas\n- Working with custom segments for granular data analysis\n\nTo get started, obtain an API key from the Settings page in your Chattermill account at https://app.chattermill.com/settings/api.",
    "version": "1.0.0",
    "contact": {
      "name": "Chattermill API Support",
      "email": "api@chattermill.io",
      "url": "https://apidocs.chattermill.com/"
    },
    "license": {
      "name": "Proprietary",
      "url": "https://chattermill.com/terms"
    }
  },
  "servers": [
    {
      "url": "https://api.chattermill.com/v1",
      "description": "Production"
    }
  ],
  "security": [
    {
      "bearerApiKey": []
    }
  ],
  "tags": [
    {
      "name": "Projects",
      "description": "Query available projects. Use the project key to scope requests to other endpoints."
    },
    {
      "name": "Responses",
      "description": "Add, query, search, and delete feedback responses."
    },
    {
      "name": "Data Sources",
      "description": "Access integrated data sources such as Zendesk, Typeform, Intercom, and others."
    },
    {
      "name": "Data Types",
      "description": "Query available data types like NPS, CSAT, reviews, and survey responses."
    },
    {
      "name": "Themes",
      "description": "Access AI-generated themes applied to processed feedback responses."
    },
    {
      "name": "Categories",
      "description": "Work with response categories for organizing and classifying feedback."
    },
    {
      "name": "Custom Segments",
      "description": "Access custom segments for granular data filtering and analysis."
    },
    {
      "name": "Metrics",
      "description": "Query aggregated metrics such as NPS, CSAT, and custom metric formulas."
    },
    {
      "name": "Insights",
      "description": "Access AI-powered insights derived from feedback analysis. This feature is currently in beta."
    }
  ],
  "paths": {
    "/projects": {
      "get": {
        "operationId": "listProjects",
        "summary": "List projects",
        "description": "Retrieves a list of all projects accessible with the current API key. Each project includes a unique key that is used to scope requests to other endpoints.",
        "tags": ["Projects"],
        "responses": {
          "200": {
            "description": "A list of projects.",
            "content": {
              "application/json": {
                "schema": {
                  "type": "object",
                  "properties": {
                    "data": {
                      "type": "array",
                      "items": {
                        "$ref": "#/components/schemas/Project"
                      }
                    }
                  }
                }
              }
            }
          },
          "401": {
            "$ref": "#/components/responses/Unauthorized"
          },
          "429": {
            "$ref": "#/components/responses/RateLimited"
          },
          "500": {
            "$ref": "#/components/responses/InternalServerError"
          }
        }
      }
    },
    "/projects/{project_key}": {
      "get": {
        "operationId": "getProject",
        "summary": "Get a project",
        "description": "Retrieves details of a specific project by its key.",
        "tags": ["Projects"],
        "parameters": [
          {
            "$ref": "#/components/parameters/ProjectKeyPath"
          }
        ],
        "responses": {
          "200": {
            "description": "The project details.",
            "content": {
              "application/json": {
                "schema": {
                  "type": "object",
                  "properties": {
                    "data": {
                      "$ref": "#/components/schemas/Project"
                    }
                  }
                }
              }
            }
          },
          "401": {
            "$ref": "#/components/responses/Unauthorized"
          },
          "404": {
            "$ref": "#/components/responses/NotFound"
          },
          "429": {
            "$ref": "#/components/responses/RateLimited"
          },
          "500": {
            "$ref": "#/components/responses/InternalServerError"
          }
        }
      }
    },
    "/responses": {
      "get": {
        "operationId": "listResponses",
        "summary": "List responses",
        "description": "Retrieves a paginated list of feedback responses. Use query parameters to filter by project, date range, data source, data type, and to paginate through results using cursor-based pagination with `after_id`.",
        "tags": ["Responses"],
        "parameters": [
          {
            "name": "project_key",
            "in": "query",
            "required": true,
            "description": "The project key to scope the responses query. Obtain this from the `/projects` endpoint.",
            "schema": {
              "type": "string"
            }
          },
          {
            "name": "date_from",
            "in": "query",
            "required": false,
            "description": "Start of the date range filter (ISO 8601 format, e.g. `2024-01-01T00:00:00Z`).",
            "schema": {
              "type": "string",
              "format": "date-time"
            }
          },
          {
            "name": "date_to",
            "in": "query",
            "required": false,
            "description": "End of the date range filter (ISO 8601 format, e.g. `2024-01-31T23:59:59Z`).",
            "schema": {
              "type": "string",
              "format": "date-time"
            }
          },
          {
            "name": "data_source",
            "in": "query",
            "required": false,
            "description": "Filter responses by data source key (e.g. `zendesk`, `typeform`).",
            "schema": {
              "type": "string"
            }
          },
          {
            "name": "data_type",
            "in": "query",
            "required": false,
            "description": "Filter responses by data type key (e.g. `nps`, `review`, `csat`).",
            "schema": {
              "type": "string"
            }
          },
          {
            "name": "after_id",
            "in": "query",
            "required": false,
            "description": "Cursor-based pagination. Provide the last response `id` from the previous page to fetch the next set of results.",
            "schema": {
              "type": "string"
            }
          },
          {
            "name": "per_page",
            "in": "query",
            "required": false,
            "description": "Number of responses to return per page.",
            "schema": {
              "type": "integer",
              "minimum": 1,
              "maximum": 100,
              "default": 25
            }
          }
        ],
        "responses": {
          "200": {
            "description": "A paginated list of responses.",
            "content": {
              "application/json": {
                "schema": {
                  "type": "object",
                  "properties": {
                    "data": {
                      "type": "array",
                      "items": {
                        "$ref": "#/components/schemas/Response"
                      }
                    },
                    "meta": {
                      "$ref": "#/components/schemas/PaginationMeta"
                    }
                  }
                }
              }
            }
          },
          "400": {
            "$ref": "#/components/responses/BadRequest"
          },
          "401": {
            "$ref": "#/components/responses/Unauthorized"
          },
          "429": {
            "$ref": "#/components/responses/RateLimited"
          },
          "500": {
            "$ref": "#/components/responses/InternalServerError"
          }
        }
      },
      "post": {
        "operationId": "createResponse",
        "summary": "Create a response",
        "description": "Adds a new feedback response to a project. Before creating a response, query `/projects`, `/data_sources`, and `/data_types` to obtain the required keys. If the needed data source or data type does not exist, contact Chattermill Support to have it created.",
        "tags": ["Responses"],
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "$ref": "#/components/schemas/ResponseCreate"
              }
            }
          }
        },
        "responses": {
          "201": {
            "description": "The response was created successfully.",
            "content": {
              "application/json": {
                "schema": {
                  "type": "object",
                  "properties": {
                    "data": {
                      "$ref": "#/components/schemas/Response"
                    }
                  }
                }
              }
            }
          },
          "400": {
            "$ref": "#/components/responses/BadRequest"
          },
          "401": {
            "$ref": "#/components/responses/Unauthorized"
          },
          "422": {
            "$ref": "#/components/responses/UnprocessableEntity"
          },
          "429": {
            "$ref": "#/components/responses/RateLimited"
          },
          "500": {
            "$ref": "#/components/responses/InternalServerError"
          }
        }
      }
    },
    "/responses/search": {
      "post": {
        "operationId": "searchResponses",
        "summary": "Search responses",
        "description": "Searches for responses by any response attribute such as email, customer ID, or other metadata fields. Commonly used to find responses for GDPR data erasure requests.",
        "tags": ["Responses"],
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "$ref": "#/components/schemas/ResponseSearchRequest"
              }
            }
          }
        },
        "responses": {
          "200": {
            "description": "A list of matching responses.",
            "content": {
              "application/json": {
                "schema": {
                  "type": "object",
                  "properties": {
                    "data": {
                      "type": "array",
                      "items": {
                        "$ref": "#/components/schemas/Response"
                      }
                    }
                  }
                }
              }
            }
          },
          "400": {
            "$ref": "#/components/responses/BadRequest"
          },
          "401": {
            "$ref": "#/components/responses/Unauthorized"
          },
          "429": {
            "$ref": "#/components/responses/RateLimited"
          },
          "500": {
            "$ref": "#/components/responses/InternalServerError"
          }
        }
      }
    },
    "/responses/{response_id}": {
      "get": {
        "operationId": "getResponse",
