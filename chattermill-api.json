  "components": {
    "securitySchemes": {
      "bearerApiKey": {
        "type": "http",
        "scheme": "bearer",
        "description": "API Key authentication. Obtain your API key from the Settings page in your Chattermill account at https://app.chattermill.com/settings/api. Provide it as a Bearer token in the Authorization header: `Authorization: Bearer {api_key}`."
      },
      "oauth2": {
        "type": "oauth2",
        "description": "OAuth 2.0 authentication for partner and third-party integrations. Used by the Chattermill Partner API for delegated access to Chattermill resources on behalf of users.",
        "flows": {
          "authorizationCode": {
            "authorizationUrl": "https://app.chattermill.com/oauth/authorize",
            "tokenUrl": "https://app.chattermill.com/oauth/token",
            "refreshUrl": "https://app.chattermill.com/oauth/token",
            "scopes": {
              "read:projects": "Read access to projects",
              "read:responses": "Read access to feedback responses",
              "write:responses": "Create and update feedback responses",
              "delete:responses": "Delete feedback responses",
              "read:data_sources": "Read access to data sources",
              "read:data_types": "Read access to data types",
              "read:themes": "Read access to themes",
              "read:categories": "Read access to categories",
              "read:custom_segments": "Read access to custom segments",
              "read:metrics": "Read access to metrics",
              "read:insights": "Read access to insights"
            }
          }
        }
      }
    },
    "parameters": {
      "ProjectKeyPath": {
        "name": "project_key",
        "in": "path",
        "required": true,
        "description": "The unique key identifying a project. Typically a lowercase, hyphenated version of your company or project name.",
        "schema": {
          "type": "string"
        }
      },
      "ResponseIdPath": {
        "name": "response_id",
        "in": "path",
        "required": true,
        "description": "The unique identifier of a feedback response.",
        "schema": {
          "type": "string"
        }
      }
    },
    "schemas": {
      "Project": {
        "type": "object",
        "properties": {
          "id": {
            "type": "string",
            "description": "Unique identifier for the project."
          },
          "key": {
            "type": "string",
            "description": "Unique key for referencing the project in API requests."
          },
          "name": {
            "type": "string",
            "description": "Display name of the project."
          },
          "description": {
            "type": "string",
            "nullable": true,
            "description": "Optional description of the project."
          },
          "created_at": {
            "type": "string",
            "format": "date-time",
            "description": "Timestamp when the project was created."
          },
          "updated_at": {
            "type": "string",
            "format": "date-time",
            "description": "Timestamp when the project was last updated."
          }
        },
        "required": ["id", "key", "name"]
      },
      "Response": {
        "type": "object",
        "properties": {
          "id": {
            "type": "string",
            "description": "Unique identifier for the response."
          },
          "comment": {
            "type": "string",
            "nullable": true,
            "description": "The text content of the customer feedback."
          },
          "score": {
            "type": "number",
            "nullable": true,
            "description": "Numerical rating or score provided by the customer (e.g. NPS score 0-10, CSAT score 1-5)."
          },
          "user_id": {
            "type": "string",
            "nullable": true,
            "description": "External identifier of the user who submitted the feedback."
          },
          "data_source": {
            "$ref": "#/components/schemas/DataSourceRef"
          },
          "data_type": {
            "$ref": "#/components/schemas/DataTypeRef"
          },
          "project_key": {
            "type": "string",
            "description": "Key of the project this response belongs to."
          },
          "metadata": {
            "type": "object",
            "nullable": true,
            "additionalProperties": true,
            "description": "Arbitrary key-value metadata associated with the response (e.g. customer email, location, product)."
          },
          "themes": {
            "type": "array",
            "nullable": true,
            "items": {
              "$ref": "#/components/schemas/ThemeAssignment"
            },
            "description": "AI-generated themes assigned to this response after processing."
          },
          "sentiment": {
            "type": "string",
            "nullable": true,
            "enum": ["positive", "negative", "neutral", "mixed"],
            "description": "Overall sentiment detected in the feedback."
          },
          "created_at": {
            "type": "string",
            "format": "date-time",
            "description": "Timestamp when the original feedback was submitted."
          },
          "processed_at": {
            "type": "string",
            "format": "date-time",
            "nullable": true,
            "description": "Timestamp when the response was processed by Chattermill's AI engine."
          },
          "updated_at": {
            "type": "string",
            "format": "date-time",
            "description": "Timestamp when the response was last updated."
          }
        },
        "required": ["id", "project_key", "created_at"]
      },
      "ResponseCreate": {
        "type": "object",
        "properties": {
          "project_key": {
            "type": "string",
            "description": "The project key to add the response to."
          },
          "comment": {
            "type": "string",
            "nullable": true,
            "description": "The text content of the customer feedback."
          },
          "score": {
            "type": "number",
            "nullable": true,
            "description": "Numerical rating or score provided by the customer."
          },
          "user_id": {
            "type": "string",
            "nullable": true,
            "description": "External identifier of the user who submitted the feedback."
          },
          "data_source_key": {
            "type": "string",
            "description": "Key of the data source (obtain from `/data_sources`)."
          },
          "data_type_key": {
            "type": "string",
            "description": "Key of the data type (obtain from `/data_types`)."
          },
          "metadata": {
            "type": "object",
            "nullable": true,
            "additionalProperties": true,
            "description": "Arbitrary key-value metadata to associate with the response."
          },
          "created_at": {
            "type": "string",
            "format": "date-time",
            "description": "Timestamp when the original feedback was submitted. Defaults to the current time if not provided."
          }
        },
        "required": ["project_key", "data_source_key", "data_type_key"]
      },
      "ResponseUpdate": {
        "type": "object",
        "properties": {
          "comment": {
            "type": "string",
            "nullable": true,
            "description": "Updated text content of the customer feedback."
          },
          "score": {
            "type": "number",
            "nullable": true,
            "description": "Updated numerical rating or score."
          },
          "metadata": {
            "type": "object",
            "nullable": true,
            "additionalProperties": true,
            "description": "Updated metadata. Merges with existing metadata."
          }
        }
      },
      "ResponseSearchRequest": {
        "type": "object",
        "properties": {
          "project_key": {
            "type": "string",
            "description": "The project key to search within."
          },
          "attributes": {
            "type": "object",
            "additionalProperties": true,
            "description": "Key-value pairs to match against response fields and metadata (e.g. `{\"email\": \"user@example.com\"}` or `{\"user_id\": \"12345\"}`)."
          }
        },
        "required": ["project_key", "attributes"]
      },
      "DataSource": {
        "type": "object",
        "properties": {
          "id": {
            "type": "string",
            "description": "Unique identifier for the data source."
          },
          "key": {
            "type": "string",
            "description": "Unique key for referencing the data source in API requests."
          },
          "name": {
            "type": "string",
            "description": "Display name of the data source."
          },
          "description": {
            "type": "string",
            "nullable": true,
            "description": "Optional description of the data source."
          },
          "created_at": {
            "type": "string",
            "format": "date-time",
            "description": "Timestamp when the data source was created."
          }
        },
        "required": ["id", "key", "name"]
      },
      "DataSourceRef": {
        "type": "object",
        "properties": {
          "key": {
            "type": "string",
            "description": "Data source key."
          },
          "name": {
            "type": "string",
            "description": "Data source display name."
          }
        }
      },
      "DataType": {
        "type": "object",
        "properties": {
          "id": {
            "type": "string",
            "description": "Unique identifier for the data type."
          },
          "key": {
            "type": "string",
            "description": "Unique key for referencing the data type in API requests."
          },
          "name": {
            "type": "string",
            "description": "Display name of the data type."
          },
          "description": {
            "type": "string",
            "nullable": true,
            "description": "Optional description of the data type."
          },
          "created_at": {
            "type": "string",
            "format": "date-time",
            "description": "Timestamp when the data type was created."
          }
        },
        "required": ["id", "key", "name"]
      },
      "DataTypeRef": {
        "type": "object",
        "properties": {
          "key": {
            "type": "string",
            "description": "Data type key."
          },
          "name": {
            "type": "string",
            "description": "Data type display name."
          }
        }
      },
      "Theme": {
        "type": "object",
        "properties": {
          "id": {
            "type": "string",
            "description": "Unique identifier for the theme."
          },
          "name": {
            "type": "string",
            "description": "Display name of the theme."
          },
          "sentiment": {
            "type": "string",
            "enum": ["positive", "negative", "neutral"],
            "description": "Default sentiment classification associated with this theme."
          },
          "category": {
            "$ref": "#/components/schemas/CategoryRef"
          },
          "response_count": {
            "type": "integer",
            "description": "Number of responses tagged with this theme."
          },
          "created_at": {
            "type": "string",
            "format": "date-time",
            "description": "Timestamp when the theme was created."
          },
          "updated_at": {
            "type": "string",
            "format": "date-time",
            "description": "Timestamp when the theme was last updated."
          }
        },
        "required": ["id", "name", "sentiment"]
      },
      "ThemeAssignment": {
        "type": "object",
        "description": "A theme assignment on a specific response, including the sentiment detected for that response.",
        "properties": {
          "theme_id": {
            "type": "string",
            "description": "Identifier of the assigned theme."
          },
          "theme_name": {
            "type": "string",
            "description": "Display name of the assigned theme."
          },
          "sentiment": {
            "type": "string",
            "enum": ["positive", "negative", "neutral"],
            "description": "Sentiment detected for this theme in the context of the response."
          }
        }
      },
      "Category": {
        "type": "object",
        "properties": {
          "id": {
            "type": "string",
            "description": "Unique identifier for the category."
          },
          "name": {
            "type": "string",
            "description": "Display name of the category."
          },
          "parent_id": {
            "type": "string",
            "nullable": true,
            "description": "Identifier of the parent category, if this is a subcategory."
          },
          "theme_count": {
            "type": "integer",
            "description": "Number of themes grouped under this category."
          },
          "created_at": {
            "type": "string",
            "format": "date-time",
            "description": "Timestamp when the category was created."
          },
          "updated_at": {
            "type": "string",
            "format": "date-time",
            "description": "Timestamp when the category was last updated."
          }
        },
        "required": ["id", "name"]
      },
      "CategoryRef": {
        "type": "object",
        "properties": {
          "id": {
            "type": "string",
            "description": "Category identifier."
          },
          "name": {
            "type": "string",
            "description": "Category display name."
          }
        }
      },
      "CustomSegment": {
        "type": "object",
        "properties": {
          "id": {
            "type": "string",
            "description": "Unique identifier for the custom segment."
          },
          "key": {
            "type": "string",
            "description": "Unique key for referencing the custom segment."
          },
          "name": {
            "type": "string",
            "description": "Display name of the custom segment."
          },
          "description": {
            "type": "string",
            "nullable": true,
            "description": "Optional description of the custom segment."
          },
          "values": {
            "type": "array",
            "items": {
              "type": "string"
            },
            "description": "Available values for this segment."
          },
          "created_at": {
            "type": "string",
            "format": "date-time",
            "description": "Timestamp when the custom segment was created."
          },
          "updated_at": {
            "type": "string",
            "format": "date-time",
            "description": "Timestamp when the custom segment was last updated."
          }
        },
        "required": ["id", "key", "name"]
      },
      "Metric": {
        "type": "object",
        "properties": {
          "id": {
            "type": "string",
            "description": "Unique identifier for the metric."
          },
          "name": {
            "type": "string",
            "description": "Name of the metric (e.g. NPS, CSAT, Sentiment Score)."
          },
          "type": {
            "type": "string",
            "enum": ["nps", "csat", "sentiment", "custom"],
            "description": "The type of metric."
          },
          "value": {
            "type": "number",
            "description": "The computed metric value."
          },
          "total_responses": {
            "type": "integer",
            "description": "Total number of responses used to compute this metric."
          },
          "date_from": {
            "type": "string",
            "format": "date-time",
            "nullable": true,
            "description": "Start of the date range used for computation."
          },
          "date_to": {
            "type": "string",
            "format": "date-time",
            "nullable": true,
            "description": "End of the date range used for computation."
          }
        },
        "required": ["id", "name", "type", "value"]
      },
      "Insight": {
        "type": "object",
        "properties": {
          "id": {
            "type": "string",
            "description": "Unique identifier for the insight."
          },
          "title": {
            "type": "string",
            "description": "Short title summarizing the insight."
          },
          "description": {
            "type": "string",
            "description": "Detailed description of the insight and its implications."
          },
          "type": {
            "type": "string",
            "enum": ["trend", "anomaly", "opportunity", "risk"],
            "description": "Classification of the insight type."
          },
          "severity": {
            "type": "string",
            "enum": ["low", "medium", "high", "critical"],
            "description": "Severity or importance level of the insight."
          },
          "related_themes": {
            "type": "array",
            "items": {
              "$ref": "#/components/schemas/CategoryRef"
            },
            "description": "Themes related to this insight."
          },
          "created_at": {
            "type": "string",
            "format": "date-time",
            "description": "Timestamp when the insight was generated."
          }
        },
        "required": ["id", "title", "description", "type"]
      },
      "PaginationMeta": {
        "type": "object",
        "properties": {
          "total": {
            "type": "integer",
            "description": "Total number of records matching the query."
          },
          "per_page": {
            "type": "integer",
            "description": "Number of records returned per page."
          },
          "has_more": {
            "type": "boolean",
            "description": "Whether there are more pages available."
          },
          "last_id": {
            "type": "string",
            "nullable": true,
            "description": "The ID of the last record in the current page. Use as the `after_id` parameter to fetch the next page."
          }
        }
      },
      "Error": {
        "type": "object",
        "properties": {
          "error": {
            "type": "object",
            "properties": {
              "code": {
                "type": "string",
                "description": "Machine-readable error code."
              },
              "message": {
                "type": "string",
                "description": "Human-readable error message."
              },
              "details": {
                "type": "array",
                "nullable": true,
                "items": {
                  "type": "object",
                  "properties": {
                    "field": {
                      "type": "string",
                      "description": "The field that caused the error."
                    },
                    "message": {
                      "type": "string",
                      "description": "Specific error message for the field."
                    }
                  }
                },
                "description": "Additional details about validation errors."
              }
            },
            "required": ["code", "message"]
          }
        }
      }
    },
    "responses": {
      "BadRequest": {
        "description": "The request was malformed or contained invalid parameters.",
        "content": {
          "application/json": {
            "schema": {
              "$ref": "#/components/schemas/Error"
            }
          }
        }
      },
      "Unauthorized": {
        "description": "Authentication failed. The API key is missing, invalid, or expired.",
        "content": {
          "application/json": {
            "schema": {
              "$ref": "#/components/schemas/Error"
            }
          }
        }
      },
      "NotFound": {
        "description": "The requested resource was not found.",
        "content": {
          "application/json": {
            "schema": {
              "$ref": "#/components/schemas/Error"
            }
          }
        }
      },
      "UnprocessableEntity": {
        "description": "The request body was well-formed but contained semantic errors.",
        "content": {
          "application/json": {
            "schema": {
              "$ref": "#/components/schemas/Error"
            }
          }
        }
      },
      "RateLimited": {
        "description": "Too many requests. You have exceeded the rate limit.",
        "content": {
          "application/json": {
            "schema": {
              "$ref": "#/components/schemas/Error"
            }
          }
        }
      },
      "InternalServerError": {
        "description": "An unexpected server error occurred.",
        "content": {
          "application/json": {
            "schema": {
              "$ref": "#/components/schemas/Error"
            }
          }
        }
      }
    }
  }
}